{
  "expo": {
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow FlexiWalls to access your photos.",
          "savePhotosPermission": "Allow FlexiWalls to save wallpapers to your gallery.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "name": "FlexiWalls",
    "slug": "flexiwalls",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flexiwalls",
    "android": {
      "package": "com.flexiwalls.app",
      "permissions": [
        "SET_WALLPAPER"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0819"
      }
    },
    "extra": {
      "appName": "FlexiWalls"
    }
  }
}
