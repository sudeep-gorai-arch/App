{
  "expo": {
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow FlexiWalls to access your photos.",
          "savePhotosPermission": "Allow FlexiWalls to save wallpapers to your gallery.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      "expo-video"
    ],
    "name": "FlexiWalls",
    "slug": "flexiwalls",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flexiwalls",
    "android": {
      "package": "com.flexiwalls.app",
      "permissions": [
        "SET_WALLPAPER",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0819"
      }
    },
    "extra": {
      "appName": "FlexiWalls",
      "eas": {
        "projectId": "06448efd-a8b5-4248-9695-13dd5b6428a9"
      }
    }
  }
}
